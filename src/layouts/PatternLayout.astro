---
import '../styles/global.css';
import type { DesignPattern } from '@/types/pattern';
import { categoryNames, difficultyLabels } from '@/data/categories';

interface Props {
  pattern: DesignPattern;
}

const { pattern } = Astro.props;
const categoryName = categoryNames[pattern.category] || pattern.category;
const difficultyName = difficultyLabels[pattern.difficulty] || pattern.difficulty;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pattern.intent} />
    <title>{pattern.name} - {pattern.nameEn} | 秋云设计模式</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet">
  </head>
  <body class="bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100 antialiased">
    <!-- 导航 -->
    <nav class="fixed top-0 left-0 right-0 z-50 px-6 md:px-12 lg:px-24 py-6 bg-white/80 dark:bg-slate-950/80 backdrop-blur-sm">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-4">
          <a href="/" class="text-sm font-medium tracking-wide">秋云设计模式</a>
          <span class="text-slate-300">/</span>
          <a href="/patterns" class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">模式</a>
          <span class="text-slate-300">/</span>
          <span class="text-sm text-slate-900 dark:text-white">{pattern.name}</span>
        </div>
        <div class="flex items-center gap-8">
          <button 
            id="theme-toggle"
            class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors"
            aria-label="切换主题"
          >
            <span class="dark:hidden">暗色</span>
            <span class="hidden dark:inline">亮色</span>
          </button>
        </div>
      </div>
    </nav>

    <!-- 锚点导航 -->
    <aside class="hidden lg:block fixed left-8 top-32 w-48">
      <nav class="space-y-2">
        <a href="#overview" class="block text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors py-1">概述</a>
        <a href="#structure" class="block text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors py-1">结构</a>
        <a href="#analogy" class="block text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors py-1">生活类比</a>
        <a href="#implementation" class="block text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors py-1">代码实现</a>
        <a href="#examples" class="block text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors py-1">实际应用</a>
        <a href="#quiz" class="block text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors py-1">练习</a>
        <a href="#related" class="block text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors py-1">相关模式</a>
      </nav>
    </aside>

    <!-- 主内容 -->
    <main class="pt-24 pb-24 px-6 md:px-12 lg:px-24 lg:pl-64">
      <div class="max-w-3xl mx-auto">
        <!-- Hero 区域 -->
        <header class="mb-16">
          <div class="flex items-center gap-4 mb-6">
            <span class="text-xs text-slate-400 uppercase tracking-widest">{categoryName}</span>
            <span class="text-xs text-slate-400">{difficultyName}</span>
          </div>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-light text-slate-900 dark:text-white mb-4">
            {pattern.name}
          </h1>
          <p class="text-lg text-slate-500 dark:text-slate-400 mb-6">
            {pattern.nameEn}
          </p>
          <p class="text-xl text-slate-700 dark:text-slate-300 leading-relaxed">
            {pattern.intent}
          </p>
        </header>

        <!-- 内容插槽 -->
        <slot />

        <!-- 上一篇/下一篇导航 -->
        <footer class="mt-24 pt-12 border-t border-slate-100 dark:border-slate-800">
          <div class="flex items-center justify-between">
            <a href="#" class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">
              ← 上一篇
            </a>
            <a href="#" class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">
              下一篇 →
            </a>
          </div>
        </footer>
      </div>
    </main>

    <!-- Footer -->
    <footer class="py-12 px-6 md:px-12 lg:px-24 border-t border-slate-100 dark:border-slate-900">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <span class="text-sm text-slate-400">秋云设计模式</span>
        <div class="flex items-center gap-6">
          <a href="https://github.com" target="_blank" class="text-sm text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors">GitHub</a>
          <a href="/about" class="text-sm text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors">关于</a>
        </div>
      </div>
    </footer>

    <script>
      // 主题切换
      const themeToggle = document.getElementById('theme-toggle');
      const html = document.documentElement;

      const savedTheme = localStorage.getItem('theme');
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

      if (savedTheme === 'dark' || (!savedTheme && systemPrefersDark)) {
        html.classList.add('dark');
      }

      themeToggle?.addEventListener('click', () => {
        html.classList.toggle('dark');
        const isDark = html.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });

      // 锚点平滑滚动
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    </script>
  </body>
</html>
