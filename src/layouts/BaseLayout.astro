---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonicalURL?: string;
  noindex?: boolean;
}

const { 
  title = '秋云设计模式',
  description = '23种经典设计模式学习 - 以清晰、优雅的方式呈现。让复杂变得简单，让学习成为享受。',
  keywords = '设计模式, Design Patterns, GoF, 单例模式, 工厂模式, 观察者模式, 面向对象, SOLID原则',
  ogImage = '/logo.png',
  canonicalURL = Astro.url.pathname,
  noindex = false,
} = Astro.props;

const siteURL = 'https://patterns.qiuyun.dev';
const fullCanonicalURL = `${siteURL}${canonicalURL}`;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <!-- 基础 SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="秋云设计模式" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={fullCanonicalURL} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullCanonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteURL}${ogImage}`} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="秋云设计模式" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={fullCanonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={`${siteURL}${ogImage}`} />
    
    <!-- 字体预加载 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet">
    
    <!-- 结构化数据 -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "秋云设计模式",
      "description": "23种经典设计模式学习平台",
      "url": "https://patterns.qiuyun.dev",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://patterns.qiuyun.dev/patterns?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>
    
    <slot name="head" />
  </head>
  <body class="bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100 antialiased">
    <!-- 导航 -->
    <nav class="fixed top-0 left-0 right-0 z-50 px-6 md:px-12 lg:px-24 py-6">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
          <img src="/logo.png" alt="秋云设计模式" class="h-6 w-auto" />
          <span class="text-sm font-medium tracking-wide">秋云设计模式</span>
        </a>
        <div class="flex items-center gap-8">
          <a href="/" class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">首页</a>
          <a href="/patterns" class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">模式</a>
          <a href="/learning-path" class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">学习路径</a>
          <a href="/statistics" class="text-sm text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors">统计</a>
          <slot name="nav-extra" />
          <button 
            id="theme-toggle"
            class="text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors"
            aria-label="切换主题"
          >
            <!-- 太阳图标 - 亮色模式时显示 -->
            <svg class="dark:hidden w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="4" stroke-width="1.5"/>
              <path stroke-width="1.5" stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
            </svg>
            <!-- 月亮图标 - 暗色模式时显示 -->
            <svg class="hidden dark:block w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-width="1.5" stroke-linecap="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- 主内容 -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="py-12 px-6 md:px-12 lg:px-24 border-t border-slate-100 dark:border-slate-900">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <span class="text-sm text-slate-400">秋云设计模式</span>
        <div class="flex items-center gap-6">
          <a href="/prerequisites" class="text-sm text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors">前置知识</a>
          <a href="/about" class="text-sm text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors">关于</a>
          <div class="relative group">
            <span class="text-sm text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors cursor-pointer">微信公众号</span>
            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50">
              <div class="bg-white dark:bg-slate-800 rounded-lg shadow-xl border border-slate-200 dark:border-slate-700 p-3">
                <img src="/gzh.jpg" alt="微信公众号二维码" class="max-w-80 max-h-96 w-auto h-auto object-contain rounded" />
                <div class="text-xs text-center text-slate-500 mt-2">扫码关注</div>
              </div>
              <div class="absolute top-full left-1/2 -translate-x-1/2 -mt-1 border-4 border-transparent border-t-white dark:border-t-slate-800"></div>
            </div>
          </div>
          <a href="https://github.com/qiuqyCN/qiuyun-design-pattern" target="_blank" rel="noopener noreferrer" class="text-sm text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors">GitHub</a>
        </div>
      </div>
    </footer>

    <script>
      // 主题切换
      const themeToggle = document.getElementById('theme-toggle');
      const html = document.documentElement;

      const savedTheme = localStorage.getItem('theme');
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

      if (savedTheme === 'dark' || (!savedTheme && systemPrefersDark)) {
        html.classList.add('dark');
      }

      themeToggle?.addEventListener('click', () => {
        html.classList.toggle('dark');
        const isDark = html.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>
  </body>
</html>
